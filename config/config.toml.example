# AirPlay 项目配置模板
# 复制此文件为 config/config.toml 并填入真实的配置
#
# 编辑 config/config.toml 后直接运行 `pio run`
# 脚本会自动生成 config/generated/sdkconfig.defaults，根目录不再保留 sdkconfig.defaults

[meta]
name = "cores3-airplay-core"
version = "1.0.0"
board = "m5stack-cores3"
mcu = "esp32s3"

# =========================================================================
# WiFi 网络配置
# =========================================================================
[wifi]
ssid = "YOUR_WIFI_SSID"
password = "YOUR_WIFI_PASSWORD"
enable_wpa3_sae = true
enable_compile_time_creds = false

[wifi.buffers]
static_rx_num = 16
dynamic_rx_num = 32
dynamic_tx_num = 24

[wifi.event_task]
stack_size = 4096

# =========================================================================
# AirPlay 核心
# =========================================================================
[airplay]
force_v1 = true

# =========================================================================
# 音频输出
# =========================================================================
[audio.output]
target_latency_ms = 500
max_buffer_ms = 1500
sample_rate_hz = 44100
mono_downmix = true
fidelity_mode = "pure"

[audio.resampler]
taps = 28

[audio.prealloc]
realtime_buffer_count = 2

# =========================================================================
# 实时语音 (Qwen Omni / DashScope HTTP Chat Completions)
# =========================================================================
[voice]
enabled_at_boot = true
url = "https://dashscope.aliyuncs.com/compatible-mode/v1"
api_key = "YOUR_DASHSCOPE_API_KEY"
model = "qwen3.5-omni-flash"
input_sample_rate = 8000
output_sample_rate = 24000
uplink_frame_ms = 40

[voice.transcription]
enabled = true
model = "gummy-realtime-v1"

# Local function calling (timers, device status, and speaker volume).
[voice.tools]
enabled = true

# 默认连续监听：本地 WakeNet 识别 Hi ESP 后进入会话。
[voice.activation]
enabled = true
phrase = "Hi ESP"
followup_window_ms = 60000
# AFE (Audio Front-End): always-on pipeline that bundles AEC + nsnet1 + AGC +
# VADNet + WakeNet. The legacy "afe_enabled" toggle and "rms_threshold" knob
# have been removed; VADNet on the AEC-cleaned signal is the only client VAD.

[voice.vad]
silence_timeout_ms = 700
min_speech_ms = 350
consecutive_frames = 2

[voice.session]
idle_timeout_ms = 15000
context_max_chars = 256
prompt_preset = "balanced"

[voice.health]
append_timeout_ms = 8000
debug_event_log = true

[voice.debug]
tls_heap_log = false

[voice.capture]
# Codec input gain (dB); raises RMS for client VAD if threshold is already low.
mic_in_gain_db = 33
stall_timeout_ms = 2000
recovery_retry_max = 3
stall_cycle_max = 6
recovery_cooldown_ms = 3000

# =========================================================================
# ENV.3 环境提醒（SHT30 + QMP6988 本地判断，气压仅记录）
# =========================================================================
[env]
enabled = true
poll_interval_sec = 30
cooldown_sec = 900
temp_hysteresis_c = 1
humidity_hysteresis_pct = 3
summer_temp_min_c = 23
summer_temp_max_c = 28
summer_humidity_min_pct = 40
summer_humidity_max_pct = 80
winter_temp_min_c = 20
winter_temp_max_c = 25
winter_humidity_min_pct = 30
winter_humidity_max_pct = 60
debug_log = true

# =========================================================================
# 系统级
# =========================================================================
[system]
cpu_freq_mhz = 240
flash_size_mb = 16
flash_mode = "qio"
spiram_mode = "quad"
monitor_baud = 115200
console = "usb_serial_jtag"

[system.log]
default_level = "debug"
maximum_level = "debug"
enable_colors = true
suppress_spi_master_logs = true

[system.lwip]
max_sockets = 8

[system.freertos]
allow_ext_mem_task_create = true

[system.spiram]
spiram_malloc_always_internal = 4096

# =========================================================================
# mbedTLS 加密
# =========================================================================
[tls]
default_mem_alloc = true
certificate_bundle = true
certificate_bundle_default_cmn = true

# =========================================================================
# mDNS 服务发现
# =========================================================================
[mdns]
max_services = 10
task_from_spiram = true
memory_alloc_spiram = true

# =========================================================================
# 屏幕 UI（LVGL 动画周期与语音 TLS 错峰）
# =========================================================================
[ui]
anim_interval_ms = 33
anim_stress_interval_ms = 200

# =========================================================================
# LVGL 图形
# =========================================================================
[lvgl]
build_examples = false
build_demos = false
cjk_font_enabled = true

# =========================================================================
# NVS 运行时默认值
# =========================================================================
[nvs.defaults]
device_name = "ESP32 AirPlay"
